# Agent OS — Environment Variables
# Copy to .env and fill in your values.
# Run `python agentos.py init` to set these interactively.

# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — GitHub integration
# Needs: repo scope (create repos, push, open issues)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Optional — Obsidian vault sync
# Set to the absolute path of your vault folder.
# Notes will be written to <vault>/DevOS/<project-name>/
OBSIDIAN_VAULT_PATH=/Users/you/Documents/MyVault

# Optional — default tech stack when BRIEF doesn't specify one
DEFAULT_STACK=TypeScript
