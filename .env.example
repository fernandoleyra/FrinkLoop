# FrinkLoop — Environment Variables
# Copy to .env and fill in your values.
# Run `python3 frinkloop.py init` to set these interactively.

# Required
MODEL_PROVIDER=anthropic
MODEL_NAME=claude-sonnet-4-20250514
MODEL_TIMEOUT_SECONDS=30

# Provider credentials / endpoints
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
OLLAMA_BASE_URL=http://localhost:11434
GEMINI_API_KEY=

# Optional — GitHub integration
# Needs: repo scope (create repos, push, open issues)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token

# Optional — Obsidian vault sync
# Set to the absolute path of your vault folder.
# Notes will be written to <vault>/FrinkLoop/<project-name>/
OBSIDIAN_VAULT_PATH=/Users/you/Documents/MyVault

# Optional — default tech stack when BRIEF doesn't specify one
DEFAULT_STACK=TypeScript
