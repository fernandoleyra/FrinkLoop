# ── Secrets ───────────────────────────────────────────────────────────────────
.env

# ── Personal projects ─────────────────────────────────────────────────────────
# All user projects are excluded. Only the _template is published.
projects/*
!projects/_template/
!projects/_template/**

# ── Runtime memory (project-specific state, never committed at root level) ────
memory/state.json
memory/tasks.json
memory/decisions.md
memory/blockers.md
memory/qa_report.md
memory/archive/
memory/agent_logs/
memory/research/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/*
!logs/.gitkeep

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Stray artifacts ───────────────────────────────────────────────────────────
ziqifFWO
.history/

